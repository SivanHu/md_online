# Server
PORT=8787
HOST=127.0.0.1
AUTH_TOKEN=

# Paths (relative to project root)
DOCS_ROOT=./docs
DAILY_DIR=./docs/daily
GIT_REPO_PATH=.
ALLOW_WRITE=true

# LLM (OpenAI-compatible). Leave empty to use template-only mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_ENABLED=false

# Summary defaults
SUMMARY_LANGUAGE=zh-CN
SUMMARY_STYLE=daily_standup
MAX_DIFF_CHARS=120000
