# Server
PORT=8787
HOST=127.0.0.1
AUTH_TOKEN=
# Comma-separated browser origins for CORS (defaults include Vite dev servers)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Paths (relative to project root)
DOCS_ROOT=./docs
PROJECTS_DIR=./docs/projects
GIT_REPO_PATH=.
PROJECT_NAME=md_online
ALLOW_WRITE=true

# LLM (OpenAI-compatible). Leave empty to use template-only mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_ENABLED=false

# Summary defaults
SUMMARY_LANGUAGE=zh-CN
SUMMARY_STYLE=daily_standup
MAX_DIFF_CHARS=120000
